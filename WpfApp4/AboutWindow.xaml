<Window x:Class="WpfApp4.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About AdbUI" Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">

    <Window.Resources>
        <LinearGradientBrush x:Key="RainbowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#ff0000" Offset="0.0"/>
            <GradientStop Color="#ff0000" Offset="0.14"/>
            <GradientStop Color="#ff7f00" Offset="0.14"/>
            <GradientStop Color="#ff7f00" Offset="0.28"/>
            <GradientStop Color="#ffff00" Offset="0.28"/>
            <GradientStop Color="#ffff00" Offset="0.42"/>
            <GradientStop Color="#00ff00" Offset="0.42"/>
            <GradientStop Color="#00ff00" Offset="0.57"/>
            <GradientStop Color="#0000ff" Offset="0.57"/>
            <GradientStop Color="#0000ff" Offset="0.71"/>
            <GradientStop Color="#4b0082" Offset="0.71"/>
            <GradientStop Color="#4b0082" Offset="0.85"/>
            <GradientStop Color="#8b00ff" Offset="0.85"/>
            <GradientStop Color="#8b00ff" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Grid>
        <Ellipse Width="400" Height="400" Fill="#D8E2FF" Opacity="0.3" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Ellipse.Effect>
                <BlurEffect Radius="100"/>
            </Ellipse.Effect>
        </Ellipse>

        <Border Width="460" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="#FFFFFF" CornerRadius="12" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Color="#000000" Direction="270" Opacity="0.08" ShadowDepth="5"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="32,32,32,24" HorizontalAlignment="Center">

                    <Grid Width="96" Height="96" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border BorderBrush="#E5E5EA" BorderThickness="1">
                            <Image Source="https://avatars.githubusercontent.com/u/253467328?v=4" Stretch="Fill"/>
                        </Border>
                        <Border Background="#0566D9" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-8,-4" Padding="6,2">
                            <TextBlock Text="DEV" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </Grid>

                    <TextBlock Text="ADB Studio" FontSize="32" FontWeight="SemiBold" Foreground="#1C1B1B" HorizontalAlignment="Center"/>
                    <TextBlock Text="CREATED BY YATEAM" FontSize="11" FontWeight="Bold" Foreground="#8E9192" HorizontalAlignment="Center" Margin="0,4,0,24"/>

                    <Grid Width="380" Margin="0,0,0,32">
                        <TextBlock Text="“" FontSize="80" FontFamily="Georgia" Foreground="#0566D9" Opacity="0.1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-10,-35,0,0"/>
                        <TextBlock FontSize="15" Foreground="#2A2A2A" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" LineHeight="22" Margin="15,0,15,0">
                            I honestly thought this app might be useless, and I knew others had built similar things before. But I didn't stop. I decided to build it anyway, even though I was 'vibe coding' through Claude and had to wait 5 hours between sessions. Against the odds, I successfully created it!
                        </TextBlock>
                        <TextBlock Text="”" FontSize="80" FontFamily="Georgia" Foreground="#0566D9" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-10,-55"/>
                    </Grid>

                    <Button Width="180" Height="44" Cursor="Hand" Click="Button_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#00FFFFFF"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="BorderBrush">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#C4C7C8"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="buttonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <ScaleTransform x:Name="buttonScale" ScaleX="1" ScaleY="1"/>
                                                </Border.RenderTransform>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetName="buttonBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#EBEBEF" Duration="0:0:0.2"/>
                                                                <ColorAnimation Storyboard.TargetName="buttonBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#1C1B1B" Duration="0:0:0.2"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetName="buttonBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#00FFFFFF" Duration="0:0:0.2"/>
                                                                <ColorAnimation Storyboard.TargetName="buttonBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#C4C7C8" Duration="0:0:0.2"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="buttonScale" Storyboard.TargetProperty="ScaleX" To="0.96" Duration="0:0:0.05"/>
                                                                <DoubleAnimation Storyboard.TargetName="buttonScale" Storyboard.TargetProperty="ScaleY" To="0.96" Duration="0:0:0.05"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="buttonScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.1"/>
                                                                <DoubleAnimation Storyboard.TargetName="buttonScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.1"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#1C1B1B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="VIEW ON GITHUB" FontSize="12" FontWeight="SemiBold" Foreground="#1C1B1B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="1" Height="64" Background="{StaticResource RainbowBrush}">
                    <Grid>
                        <Border Background="#000000" Opacity="0.05"/>
                        <Border BorderBrush="#FFFFFF" BorderThickness="0,1,0,0" Opacity="0.3" VerticalAlignment="Top"/>
                        <TextBlock Text="I'm lazy" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="4" Color="Black" Direction="270" Opacity="0.3" ShadowDepth="1"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>