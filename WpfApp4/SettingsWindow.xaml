<Window x:Class="WpfApp4.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="640" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Локальные копии стилей, чтобы окно не зависело от MainWindow.xaml.Resources -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Background" Value="{StaticResource SurfaceContainerBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineVariantBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SecondaryContainerBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box" Width="18" Height="18" CornerRadius="5"
                                    BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1.5"
                                    Background="{StaticResource SurfaceBrush}">
                                <Path x:Name="CheckMark" Data="M2,7 L6,11 L14,2" Stroke="White" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Visibility="Collapsed" Stretch="Uniform" Margin="3"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceContainerBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineVariantBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Пути к инструментам -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Инструменты (ADB / scrcpy)" Style="{StaticResource SectionTitle}"/>

                        <CheckBox x:Name="UseCustomDirCheck" Content="Использовать свою директорию для adb и scrcpy"
                                  Checked="UseCustomDirCheck_Changed" Unchecked="UseCustomDirCheck_Changed" Margin="0,0,0,12"/>

<TextBlock Text="Папка с ADB (adb.exe, fastboot.exe, AdbWinApi.dll и т.д.)"
           FontSize="11" Foreground="{StaticResource SecondaryBrush}" Margin="0,0,0,4" TextWrapping="Wrap"/>
<Grid Margin="0,0,0,10">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
    <TextBox x:Name="AdbDirBox" Padding="8,6" FontFamily="Consolas" FontSize="12" IsReadOnly="True"/>
    <Button Grid.Column="1" Content="Обзор…" Style="{StaticResource ToolbarButton}"
        Margin="8,0,0,0" Click="BrowseAdbDir_Click"/>
</Grid>

<TextBlock Text="Папка со scrcpy (scrcpy.exe и его библиотеки)"
           FontSize="11" Foreground="{StaticResource SecondaryBrush}" Margin="0,0,0,4" TextWrapping="Wrap"/>
<Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
    <TextBox x:Name="ScrcpyDirBox" Padding="8,6" FontFamily="Consolas" FontSize="12" IsReadOnly="True"/>
    <Button Grid.Column="1" Content="Обзор…" Style="{StaticResource ToolbarButton}"
        Margin="8,0,0,0" Click="BrowseScrcpyDir_Click"/>
</Grid>
                    </StackPanel>
                </Border>

                <!-- Поведение -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Поведение" Style="{StaticResource SectionTitle}"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Интервал автообновления списка устройств (сек)" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox x:Name="RefreshIntervalBox" Grid.Column="1" Padding="6" TextAlignment="Center"/>
                        </Grid>

                        <CheckBox x:Name="ConfirmPowerCheck" Content="Подтверждать выключение/перезагрузку устройства"/>
                    </StackPanel>
                </Border>

                <!-- Hot Commands -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Свои быстрые команды (Hot Commands)" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Появятся кнопками на странице Devices. Команда пишется без &quot;adb&quot;, например: shell input keyevent 26"
                                   FontSize="11" Foreground="{StaticResource SecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <ListBox x:Name="HotCommandsList" MaxHeight="160" BorderThickness="1"
                                 BorderBrush="{StaticResource OutlineVariantBrush}" Background="{StaticResource SurfaceBrush}"
                                 Margin="0,0,0,12">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding Command}" FontFamily="Consolas" FontSize="11"
                                                       Foreground="{StaticResource SecondaryBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="✕" Width="26" Height="26"
                                                Style="{StaticResource ToolbarButton}" Padding="0"
                                                Click="RemoveHotCommand_Click" Tag="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NewHotCommandName" Grid.Column="0" Padding="6" ToolTip="Название кнопки"/>
                            <TextBox x:Name="NewHotCommandValue" Grid.Column="2" Padding="6" FontFamily="Consolas"
                                     ToolTip="Например: shell input keyevent 26"/>
                            <Button Grid.Column="4" Content="Добавить" Style="{StaticResource ToolbarButton}"
                                    Click="AddHotCommand_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Style="{StaticResource ToolbarButton}" Padding="18,8" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Сохранить" Style="{StaticResource ToolbarButton}"
                    Background="{StaticResource PrimaryBrush}" Padding="18,8" Click="Save_Click">
                <Button.Foreground>White</Button.Foreground>
            </Button>
        </StackPanel>
    </Grid>
</Window>